{
  "name": "ROOT Physics Environment",
  "image": "rootproject/root:latest",
  
  // After the container starts, install Jupyter and physics libraries.
  // The '--no-deps' flag on jupyroot avoids version conflicts with ROOT's
  // own bundled packages, which can sometimes clash with pip installs.
  "postCreateCommand": "pip install numpy matplotlib scipy jupyterlab jupyroot --no-deps",
  
  // Port 8888 is Jupyter's default port. Forwarding it means your
  // browser can talk to the Jupyter server running in the cloud machine.
  "forwardPorts": [8888],
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
